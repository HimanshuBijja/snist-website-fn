# ─── Backend Connection ────────────────────────────────────────────────────────
# URL of the Express backend (snist-website-bn).
# Local:      http://localhost:5000
# Production: https://your-render-service.onrender.com
BACKEND_URL=http://localhost:5000

# API key shared between the frontend (Next.js Route Handlers) and the backend.
# Must match the API_KEY value set in snist-website-bn/.env
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=generate_a_random_64_character_hex_string_here

# ─── Admin Dashboard ───────────────────────────────────────────────────────────
# Secret used to sign/verify the admin JWT session token (jose library).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_a_random_64_character_hex_string_here

# ─── Notes ─────────────────────────────────────────────────────────────────────
# BACKEND_URL is also used in next.config.js to populate the Content-Security-Policy
# connect-src directive at build time. Make sure it is set in your Vercel
# environment variables (Settings → Environment Variables) before building.
#
# Do NOT prefix any of these with NEXT_PUBLIC_ — they are server-side only
# (used exclusively in Next.js Route Handlers, never in client components).
