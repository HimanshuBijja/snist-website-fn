# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Connection string for your MongoDB Atlas cluster (or local instance).
# Example: mongodb+srv://user:pass@cluster.mongodb.net/c3?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/c3

# ─── Gmail OAuth2 (for welcome emails) ────────────────────────────────────────
# Generate credentials at: https://console.cloud.google.com/
EMAIL_USER=your_email@gmail.com
CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
CLIENT_SECRET=your_google_oauth_client_secret
REFRESH_TOKEN=your_google_oauth_refresh_token
# The redirect URI registered in your Google Cloud Console
OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
# Password for admin login
ADMIN_PASSWORD=change_this_to_a_strong_admin_password

# Secret used to sign/verify the admin JWT session token (jose library).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=generate_a_random_64_character_hex_string_here

# ─── Notes ─────────────────────────────────────────────────────────────────────
# Do NOT prefix any of these with NEXT_PUBLIC_ — they are server-side only
# (used exclusively in Next.js Route Handlers, never in client components).
