# Frontend Environment Variables

# Backend API URL
# Development: http://localhost:5000
# Production: https://c3-backend-cnhr.onrender.com
BACKEND_URL=http://localhost:5000

# API Key for backend authentication
# Generate a secure random key and keep it secret
# This should match the API_KEY in the backend .env file
API_KEY=your_api_key_here_must_match_backend

# Optional: Analytics Keys
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Admin Dashboard
ADMIN_PASSWORD=change_this_to_a_strong_password
ADMIN_JWT_SECRET=change_this_to_a_long_random_string_for_jwt_signing

# Vercel Cron (automatically provided by Vercel, set manually for local testing)
CRON_SECRET=your_vercel_cron_secret_here
